rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    match /alunos/{uid} {
      allow create: if isAdmin();
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow update: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow delete: if false;
    }

    match /alunos/{uid}/progresso_questoes/{docId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create, update: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow delete: if false;
    }

    match /alunos/{uid}/progresso_listas/{docId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create, update: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow delete: if false;
    }

    match /alunos/{uid}/flashcards_pessoais/{docId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create, update: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow delete: if false;
    }

    match /alunos/{uid}/progresso_flashcards/{docId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create, update: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow delete: if false;
    }

    match /alunos/{uid}/trilhas/{trilhaId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow create, update: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow delete: if false;
    }

    match /flashcards/{docId} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /questoes_subassuntos/{docId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /questoes_cards/{docId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /questoes/{docId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /questions/{docId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /exams/{docId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
